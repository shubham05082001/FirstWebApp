@{
   Layout = null;
}

<!doctype html>
<html lang="en">
<head>
   <meta charset="utf-8">
   <title>Reset Password - FirstWebApp</title>
   <meta name="viewport" content="width=device-width, initial-scale=1">

   <!-- Font Awesome -->
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

   <!-- Ionicons -->
   <link rel="stylesheet" href="https://unpkg.com/ionicons@4.5.10-0/dist/css/ionicons.min.css" />

   <!-- Linearicons -->
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/linearicons@1.0.0/dist/web-font/style.css" />

   <!-- PE Icon 7 Stroke -->
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pe7-icon@1.0.4/dist/dist/pe-icon-7-stroke.min.css" />

   <!-- Slick Carousel -->
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css" />

   <!-- Your Custom Project CSS -->
   <link href="~/styles/css/base.css" rel="stylesheet" />

   <style>
         .password-eye {
            position: absolute;
            right: 15px;
            top: 48px;
            cursor: pointer;
         }
   </style>

</head>

<body>

   <div class="app-container app-theme-white body-tabs-shadow">
      <div class="app-container">
         <div class="h-100">
            <div class="h-100 g-0 row">

               <!-- LEFT SLIDER -->
               <div class="d-none d-lg-block col-lg-4">
                  <div class="slider-light">
                     <div class="slick-slider">

                        <div>
                           <div
                              class="position-relative h-100 d-flex justify-content-center align-items-center bg-plum-plate">
                              <div class="slide-img-bg" style="background-image:url('/images/originals/city.jpg');">
                              </div>
                              <div class="slider-content text-white">
                                 <h3>Password Security</h3>
                                 <p>Create strong password to secure your account access.</p>
                              </div>
                           </div>
                        </div>

                        <div>
                           <div
                              class="position-relative h-100 d-flex justify-content-center align-items-center bg-premium-dark">
                              <div class="slide-img-bg"
                                   style="background-image:url('/images/originals/citynights.jpg');"></div>
                              <div class="slider-content text-white">
                                 <h3>Enterprise Protection</h3>
                                 <p>Modern authentication flow with OTP verification.</p>
                              </div>
                           </div>
                        </div>

                     </div>
                  </div>
               </div>

               <!-- RIGHT FORM AREA -->
               <div class="h-100 d-flex bg-white justify-content-center align-items-center col-md-12 col-lg-8">
                  <div class="app-login-box col-sm-12 col-md-10 col-lg-6">

                     <div class="app-logo"></div>

                     <h4 class="mb-2">
                        <span class="d-block">Reset Your Password</span>
                        <span class="text-muted">Enter new password to continue login.</span>
                     </h4>

                     <div class="divider"></div>

                     @if (ViewBag.Error != null)
                     {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                     }

                     <form method="post">

                        <div class="position-relative mb-3">
                           <label class="form-label">New Password</label>
                           <input type="password" id="password" name="password" class="form-control"
                                  placeholder="Enter new password" required />
                           <i class="fa fa-eye password-eye" onclick="togglePassword('password')"></i>
                        </div>

                        <div class="position-relative mb-4">
                           <label class="form-label">Confirm Password</label>
                           <input type="password" id="confirmPassword" name="confirmPassword" class="form-control"
                                  placeholder="Confirm password" required />
                           <i class="fa fa-eye password-eye" onclick="togglePassword('confirmPassword')"></i>
                        </div>

                        <div class="d-flex align-items-center">
                           <div class="ms-auto">
                              <button type="submit" class="btn btn-success btn-lg">
                                 Update Password
                              </button>
                           </div>
                        </div>

                        <div class="text-center mt-3">
                           <a asp-action="Login" asp-controller="Accounts" class="text-decoration-none fw-semibold">
                              ← Back to Login
                           </a>
                        </div>

                     </form>

                  </div>
               </div>

            </div>
         </div>
      </div>
   </div>

   <!-- jQuery -->
   <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

   <!-- Slick Carousel -->
   <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

   <script>
      $('.slick-slider').slick({
      dots: true,
      autoplay: true,
      autoplaySpeed: 2500
      });

      function togglePassword(id) {
      var x = document.getElementById(id);
      if (x.type === "password") { x.type = "text"; }
      else { x.type = "password"; }
      }
   </script>

</body>

</html>