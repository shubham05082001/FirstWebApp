@{
    Layout = null;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Forgot Password - FirstWebApp</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- ArchitectUI CSS -->
    <!-- Font Awesome -->
    <link rel="stylesheet"      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Ionicons -->
    <link rel="stylesheet"      href="https://unpkg.com/ionicons@4.5.10-0/dist/css/ionicons.min.css" />

    <!-- Linearicons -->
    <link rel="stylesheet"      href="https://cdn.jsdelivr.net/npm/linearicons@1.0.0/dist/web-font/style.css" />

    <!-- PE Icon 7 Stroke -->
    <link rel="stylesheet"      href="https://cdn.jsdelivr.net/npm/pe7-icon@1.0.4/dist/dist/pe-icon-7-stroke.min.css" />

    <!-- Slick Carousel -->
    <link rel="stylesheet"      href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css" />

    <!-- Your Custom Project CSS -->
    <link href="~/styles/css/base.css" rel="stylesheet" />
</head>

<body>

    <div class="app-container app-theme-white body-tabs-shadow">
        <div class="app-container">
            <div class="h-100">
                <div class="h-100 g-0 row">

                    <!-- LEFT SLIDER -->
                    <div class="d-none d-lg-block col-lg-4">
                        <div class="slider-light">
                            <div class="slick-slider">

                                <div>
                                    <div
                                        class="position-relative h-100 d-flex justify-content-center align-items-center bg-arielle-smile">
                                        <div class="slide-img-bg"
                                             style="background-image:url('/images/originals/city.jpg');"></div>
                                        <div class="slider-content text-white">
                                            <h3>Password Recovery</h3>
                                            <p>Reset your password securely using OTP verification.</p>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <div
                                        class="position-relative h-100 d-flex justify-content-center align-items-center bg-heavy-rain">
                                        <div class="slide-img-bg"
                                             style="background-image:url('/images/originals/citynights.jpg');"></div>
                                        <div class="slider-content text-white">
                                            <h3>Secure Access</h3>
                                            <p>We protect your account with modern authentication flow.</p>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <!-- RIGHT FORM AREA -->
                    <div class="h-100 d-flex bg-white justify-content-center align-items-center col-md-12 col-lg-8">

                        <div class="app-login-box col-sm-12 col-md-8 col-lg-6">

                            <div class="app-logo"></div>

                            <h4 class="mb-2">
                                <span class="d-block">Forgot your password?</span>
                                <span class="text-muted">Enter your registered email to receive OTP.</span>
                            </h4>

                            <div class="divider"></div>

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger">@ViewBag.Error</div>
                            }

                            @if (ViewBag.Success != null)
                            {
                                <div class="alert alert-success">@ViewBag.Success</div>
                            }

                            <form method="post">

                                <div class="position-relative mb-4">
                                    <label class="form-label">Registered Email</label>
                                    <input type="email" name="email" class="form-control form-control-lg"
                                           placeholder="Enter your email..." required />
                                </div>

                                <div class="d-grid mb-3">
                                    <button class="btn btn-primary btn-lg">
                                        Send OTP
                                    </button>
                                </div>

                                <div class="text-center">
                                    <a asp-action="Login" asp-controller="Accounts"
                                           class="text-decoration-none fw-semibold">
                                        ← Back to Login
                                    </a>
                                </div>

                            </form>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- JS -->
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Slick Carousel -->
    <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

    <script>
        $(document).ready(function () {
        $('.slick-slider').slick({
        dots: true,
        autoplay: true,
        autoplaySpeed: 2500
        });
        });
    </script>

</body>

</html>